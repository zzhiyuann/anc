---
---

<section class="cta">
  <div class="container">
    <div class="cta-card">
      <div class="cta-bg">
        <div class="cta-orb"></div>
      </div>
      <div class="cta-content">
        <h2 class="cta-heading">
          Ready to run your company?
        </h2>
        <p class="cta-sub">
          Open source. Self-hosted. MIT licensed. Start in 60 seconds.
        </p>
        <div class="cta-actions">
          <a href="https://github.com/zzhiyuann/anc" target="_blank" rel="noopener" class="btn btn-primary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="margin-right: 8px;">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
          <a href="/docs" class="btn btn-ghost">
            Read the Docs
          </a>
        </div>
        <div class="cta-install">
          <code>git clone https://github.com/zzhiyuann/anc.git</code>
          <button class="copy-btn" data-copy="git clone https://github.com/zzhiyuann/anc.git" aria-label="Copy">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" />
              <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const text = (btn as HTMLElement).dataset.copy || '';
      navigator.clipboard.writeText(text);
      const svg = btn.innerHTML;
      btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>';
      setTimeout(() => { btn.innerHTML = svg; }, 1500);
    });
  });
</script>

<style>
  .cta {
    padding: var(--section-gap) 0;
    border-top: 1px solid var(--gray-3);
  }

  .cta-card {
    position: relative;
    border-radius: 20px;
    border: 1px solid var(--gray-4);
    background: var(--gray-2);
    padding: 80px 40px;
    text-align: center;
    overflow: hidden;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cta-orb {
    position: absolute;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.12), transparent 70%);
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    filter: blur(80px);
  }

  .cta-content {
    position: relative;
  }

  .cta-heading {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .cta-sub {
    font-size: 17px;
    color: var(--gray-9);
    margin-bottom: 32px;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 550;
    transition: all 0.2s;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--gray-12);
    color: var(--gray-1);
  }

  .btn-primary:hover {
    background: white;
    box-shadow: 0 0 40px rgba(255, 255, 255, 0.1);
  }

  .btn-ghost {
    border: 1px solid var(--gray-5);
    color: var(--gray-11);
  }

  .btn-ghost:hover {
    border-color: var(--gray-7);
    color: var(--gray-12);
    background: var(--gray-3);
  }

  .cta-install {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    border-radius: 8px;
    background: var(--gray-3);
    border: 1px solid var(--gray-4);
  }

  .cta-install code {
    font-size: 14px;
    color: var(--gray-10);
  }

  .copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--gray-7);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    transition: color 0.2s;
  }

  .copy-btn:hover {
    color: var(--gray-11);
  }

  @media (max-width: 640px) {
    .cta-actions {
      flex-direction: column;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }

    .cta-card {
      padding: 48px 24px;
    }
  }
</style>
