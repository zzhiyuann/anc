---
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <span class="footer-logo">ANC</span>
      <span class="footer-copy">The OS for one-person companies.</span>
    </div>
    <div class="footer-links">
      <a href="https://github.com/zzhiyuann/anc" target="_blank" rel="noopener">GitHub</a>
      <a href="/docs" target="_blank" rel="noopener">Docs</a>
      <a href="https://github.com/zzhiyuann/anc/blob/main/LICENSE" target="_blank" rel="noopener">MIT License</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--gray-3);
    padding: 32px 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .footer-logo {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--gray-10);
  }

  .footer-copy {
    font-size: 13px;
    color: var(--gray-7);
  }

  .footer-links {
    display: flex;
    gap: 24px;
  }

  .footer-links a {
    font-size: 13px;
    color: var(--gray-8);
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--gray-12);
  }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }

    .footer-left {
      flex-direction: column;
      gap: 4px;
    }
  }
</style>
