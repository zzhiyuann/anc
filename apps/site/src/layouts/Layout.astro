---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ANC — Agent Native Company',
  description = 'Stop using agents. Start running a company. The open-source AI company operating system.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Inter font -->
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <!-- JetBrains Mono for code -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;

    /* Neutral palette */
    --gray-1: #0a0a0a;
    --gray-2: #111111;
    --gray-3: #191919;
    --gray-4: #222222;
    --gray-5: #2e2e2e;
    --gray-6: #3e3e3e;
    --gray-7: #505050;
    --gray-8: #707070;
    --gray-9: #8f8f8f;
    --gray-10: #a0a0a0;
    --gray-11: #b0b0b0;
    --gray-12: #ededed;

    /* Accent — electric blue, subtle */
    --accent: #3b82f6;
    --accent-dim: #2563eb;
    --accent-glow: rgba(59, 130, 246, 0.15);

    /* Semantic */
    --green: #22c55e;
    --amber: #f59e0b;
    --red: #ef4444;

    /* Layout */
    --max-w: 1200px;
    --section-gap: clamp(64px, 8vw, 120px);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-sans);
    background: var(--gray-1);
    color: var(--gray-12);
    line-height: 1.6;
    overflow-x: hidden;
  }

  ::selection {
    background: var(--accent);
    color: white;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  /* Utility */
  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Gradient text */
  .gradient-text {
    background: linear-gradient(135deg, #ffffff 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Subtle glow effect */
  .glow {
    box-shadow: 0 0 80px var(--accent-glow);
  }
</style>
