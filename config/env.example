# ANC Environment Variables

# Linear API (required)
ANC_LINEAR_API_KEY=lin_api_...
ANC_LINEAR_TEAM_ID=<team-uuid>
ANC_LINEAR_TEAM_KEY=RYA

# Webhook
ANC_WEBHOOK_PORT=3849
ANC_WEBHOOK_SECRET=<hmac-secret>

# Workspaces
ANC_WORKSPACE_BASE=~/anc-workspaces

# Discord (bidirectional)
ANC_DISCORD_BOT_TOKEN=<discord-bot-token>
ANC_DISCORD_CHANNEL_ID=<channel-id>

# Telegram (outbound only)
ANC_TELEGRAM_BOT_TOKEN=<telegram-bot-token>
ANC_TELEGRAM_CHAT_ID=<chat-id>
